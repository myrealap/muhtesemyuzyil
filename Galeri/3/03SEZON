<script type="text/javascript">

function resizePage(){
	var docW = $(window).width();
	var docH = $(window).height();
	
	var newH = docH/2;
	
	if (newH <320) newH = 320;
	if (newH >600) newH = 600;
	
	$('.galeri_slider .images_container ul li').height(newH);
	$('.galeri_slider .images_container ul li .content').height(newH);
	$('.galeri_slider .images_container ul li .content img').height(newH);
	$('.galeri_slider .images_container').height(newH);

	var topResGenislik = 0;
	$('.galeri_slider .images_container ul li .content img').each(function(index) {
		topResGenislik += $(this).width() + 30; //30 right margin
	});

	$('.galeri_slider .mCSB_container').width(topResGenislik);

	$('.mCSB_buttonLeft').css('top',-1*newH/2);
	$('.mCSB_buttonRight').css('top',-1*newH/2);
	
}		
	
$(window).resize(function() {
  resizePage();
});
	
$(document).ready(function() {
	resizePage();	
});
 resizePage();
 
 setInterval("resizePage()",500);
 
